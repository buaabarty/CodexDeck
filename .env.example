CODEX_CONTROL_HOST=127.0.0.1
CODEX_CONTROL_PORT=5900
CODEX_CONTROL_TOKEN=replace-with-a-long-random-token
CODEX_DEFAULT_CWD=/path/to/projects
CODEX_BIN=codex

# Account + TOTP mode. Run `npm run setup:account -- your-name` first.
# CODEX_CONTROL_AUTH=account
# CODEX_CONTROL_ACCOUNT_FILE=.runtime/account.json
# CODEX_CONTROL_COOKIE_SECURE=1

# Disable app-level auth only behind a private network boundary such as
# Tailscale Serve or SSH port forwarding.
# CODEX_CONTROL_DISABLE_AUTH=1
